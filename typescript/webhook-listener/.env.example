# RouteStack
ROUTESTACK_API_KEY=your-routestack-api-key
ROUTESTACK_MCP_URL=https://mcp.routestack.ai/sse

# Webhook forwarding
FORWARD_URL=https://your-webhook-endpoint.com/events

# Event filter (comma-separated, leave empty for all events)
# EVENT_FILTER=booking.confirmed,booking.cancelled,price.changed

# Retry config (optional)
# MAX_RETRIES=3
# RETRY_DELAY_MS=1000
